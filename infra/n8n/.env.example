# Copy to .env and fill in strong values before running docker compose.
# Generate a key once: openssl rand -base64 32
N8N_ENCRYPTION_KEY=replace-with-generated-key

# Service exposure
N8N_HOST=localhost
N8N_PORT=5678
WEBHOOK_URL=http://localhost:5678/
TZ=America/New_York

# Protect the editor when exposed beyond localhost
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me

# Execution mode: regular (default) or queue
EXECUTIONS_MODE=queue

# Queue settings (used when EXECUTIONS_MODE=queue)
QUEUE_BULL_REDIS_HOST=redis
QUEUE_BULL_REDIS_PORT=6379
#QUEUE_BULL_REDIS_PASSWORD=

# Database: default SQLite lives in ./data
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=super-secret
# For SQLite fallback:
#DB_TYPE=sqlite
#DB_SQLITE_DATABASE=/home/node/.n8n/database.sqlite

# Optional: telemetry
#N8N_DIAGNOSTICS_ENABLED=false
