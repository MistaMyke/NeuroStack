{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "Node",
    "allowJs": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "incremental": true,
    "baseUrl": "./",
    "paths": {
      "@cpa/shared-types": [
        "../../packages/shared-types/src/index.ts"
      ],
      "@cpa/ui-library": [
        "../../packages/ui-library/src/index.ts"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "tailwind.config.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
